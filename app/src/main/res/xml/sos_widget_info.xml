<?xml version="1.0" encoding="utf-8"?>
<!--
    App Widget Provider metadata.
    minWidth/minHeight = 2x2 cell (110dp each cell)
    updatePeriodMillis = 0 (no automatic updates needed; SOS is event-driven)
    widgetCategory = home_screen — shown in launcher's widget picker
-->
<appwidget-provider
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="110dp"
    android:targetCellWidth="2"
    android:targetCellHeight="2"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/widget_sos"
    android:widgetCategory="home_screen"
    android:description="@string/app_name"
    android:previewImage="@mipmap/ic_launcher"
    android:resizeMode="none" />
